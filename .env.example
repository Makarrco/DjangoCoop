# Скопіюй цей файл у .env і заповни своїми значеннями.
# .env НІКОЛИ не комітиться в Git — лише .env.example.

# --- Django ---
SECRET_KEY=django-insecure-заміни-на-довгий-випадковий-рядок
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# --- База даних ---
# Локально можна залишити порожнім — тоді використається SQLite (db.sqlite3).
# Для підключення до PostgreSQL на Railway: Postgres-сервіс → Variables →
# скопіюй DATABASE_PUBLIC_URL (саме публічний, для доступу ззовні Railway).
# DATABASE_URL=postgresql://postgres:пароль@хост.proxy.rlwy.net:порт/railway

# --- Railway (продакшн) ---
# Ці змінні задаються В САМОМУ Railway (Variables вкладка сервісу),
# а не в локальному .env — тут лише для прикладу, як мають виглядати:
# DEBUG=False
# ALLOWED_HOSTS=127.0.0.1,localhost,your-app.up.railway.app
# CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app
